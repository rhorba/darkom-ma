# Database
DB_NAME=darkom
DB_USER=darkom
DB_PASSWORD=darkom_dev_password

# Auth — replace with a strong random secret before any non-local deployment
JWT_SECRET=dev-only-change-me-32-characters-minimum

# CMI (Moroccan payment gateway) — replace with real merchant credentials before enabling payments
CMI_MERCHANT_ID=changeme-cmi-merchant-id
CMI_API_KEY=changeme-cmi-api-key
CMI_SECRET_KEY=changeme-cmi-secret-key
CMI_CALLBACK_URL=http://localhost:8080/api/v1/payments/cmi/callback

# Transactional email (rent reminders)
EMAIL_API_KEY=changeme-email-api-key

# App
APP_BASE_URL=http://localhost:4200

# Host port overrides — change these if the defaults collide with another
# project's containers on your machine (docker-compose.yml falls back to
# 5432/8080/4200 if unset).
# DB_PORT_HOST=5432
# BACKEND_PORT_HOST=8080
# FRONTEND_PORT_HOST=4200
